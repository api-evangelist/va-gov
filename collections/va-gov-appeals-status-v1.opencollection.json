{
  "opencollection": "1.0.0",
  "info": {
    "name": "Appeals Status",
    "version": "v1"
  },
  "items": [
    {
      "info": {
        "name": "Appeals Status",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get appeal statuses for the claimant associated with the provided ICN.",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://sandbox-api.va.gov/services/appeals/appeals-status/{version}/appeals",
            "params": [
              {
                "name": "icn",
                "value": "1012832025V743496",
                "type": "query",
                "description": "Claimant's Integration Control Number (ICN). Optional when using a veteran-scoped token. Required when using a representative- or system-scoped token."
              }
            ],
            "auth": {
              "type": "oauth2",
              "flow": "client_credentials",
              "accessTokenUrl": "https://api.va.gov/oauth2/appeals/system/v1/token",
              "credentials": {
                "clientId": "{{clientId}}",
                "clientSecret": "{{clientSecret}}"
              }
            }
          },
          "docs": "Returns a list of all appeals for the claimant, including each appeal's current status, priority, and update history."
        }
      ]
    }
  ],
  "bundled": true
}