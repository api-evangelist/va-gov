              "credentials": {
                "clientId": "{{clientId}}",
                "clientSecret": "{{clientSecret}}"
              }
            }
          },
          "docs": "Returns the last active POA for a claimant.\nTo check the status of new POA submissions, use the GET /forms/2122/{id} endpoint.\n\n"
        },
        {
          "info": {
            "name": "21-22 POA form submission test run.",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://sandbox-api.va.gov/services/claims/{version}/forms/2122/validate",
            "headers": [
              {
                "name": "X-VA-SSN",
                "value": ""
              },
              {
                "name": "X-VA-First-Name",
                "value": ""
              },
              {
                "name": "X-VA-Last-Name",
                "value": ""
              },
