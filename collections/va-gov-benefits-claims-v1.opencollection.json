        {
          "info": {
            "name": "Submit a POA form.",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://sandbox-api.va.gov/services/claims/{version}/forms/2122",
            "headers": [
              {
                "name": "X-VA-SSN",
                "value": ""
              },
              {
                "name": "X-VA-First-Name",
                "value": ""
              },
              {
                "name": "X-VA-Last-Name",
                "value": ""
              },
              {
                "name": "X-VA-Birth-Date",
                "value": ""
